# ── Required ─────────────────────────────────────────────────
GROQ_API_KEY=

# ── Embeddings (RAG) ─────────────────────────────────────────
# Embeddings come from the Hugging Face Inference API only — there is no
# local model. This key is required for RAG to work at all.
HUGGINGFACE_KEY=

# Must match the Pinecone index dimension below (MiniLM-L6-v2 -> 384).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BATCH_SIZE=32

# ── Vector store (Pinecone) ──────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=finsage
# Optional: leave blank to use the default namespace
PINECONE_NAMESPACE=
# Only used by 'ingest_docs.py --create-index'
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Telemetry (optional) ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Must match your project's region, e.g. https://us.cloud.langfuse.com
# LANGFUSE_BASE_URL is accepted as an alias for LANGFUSE_HOST.
LANGFUSE_HOST=https://cloud.langfuse.com

# ── MCP (optional) ───────────────────────────────────────────
# Tools run in-memory inside the backend; there is no server URL to set.
MCP_ENABLED=true
MCP_TIMEOUT_SECONDS=20
